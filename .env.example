# ====== IA (OpenAI) ======
# Chave da OpenAI usada pelos agentes (orquestrador, atendimento), embeddings e
# transcrição de áudio (Whisper). Configure como variável de ambiente/segredo no
# deploy (ex.: Coolify) — NUNCA comite a chave no repositório.
OPENAI_API_KEY=""
# Modelos (opcionais — têm defaults sensatos)
OPENAI_MODEL="gpt-4o"
OPENAI_EMBED_MODEL="text-embedding-3-small"
OPENAI_TRANSCRIBE_MODEL="whisper-1"
# (Opcional) Teto diário de respostas automáticas por organização (guardrail de
# custo). Vazio ou 0 = ilimitado (padrão). Ex.: 500 limita a 500 respostas/dia;
# ao exceder, o atendimento é transferido para um humano.
AI_DAILY_LIMIT=""

# ====== App / Auth ======
APP_URL="https://zapflowia.tesseractauto.com.br"
# Segredo para assinar os tokens JWT. OBRIGATÓRIO em produção — use um valor longo
# e aleatório (>=32 chars). Sem ele, um segredo aleatório é gerado a cada boot
# (sessões caem a cada deploy). Gere com: openssl rand -hex 32
JWT_SECRET=""
# Conta do administrador master (super-admin). MASTER_ADMIN_PASSWORD define/rotaciona
# a senha no boot — defina para substituir a senha antiga exposta.
MASTER_ADMIN_EMAIL="eldastito@gmail.com"
MASTER_ADMIN_PASSWORD=""
# Segredo do webhook: se definido, o webhook (Evolution/Meta) exige este valor em
# ?secret=... (ou header x-webhook-secret). Configure na URL do webhook na Evolution.
WEBHOOK_SECRET=""
# Token de verificação do webhook da Meta (WhatsApp Cloud / Instagram).
META_VERIFY_TOKEN=""
# Instagram (API with Instagram Login) — App ID e App Secret do app na Meta.
# Necessários para o login OAuth de 1 clique (captura o token completo das DMs).
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
# Origem permitida para o WebSocket/CORS em produção. Vazio = reflete a origem.
CORS_ORIGIN="https://zapflowia.tesseractauto.com.br"
ALLOWED_ORIGINS="https://zapflowia.tesseractauto.com.br"

# ====== EVOLUTION API ======
EVOLUTION_BASE_URL="https://evolutiongo.tesseractauto.com.br"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME="ExaForge"

# ====== ZappFlow Vision Cloud (docs/adr/ADR-001, adendo) ======
# Processo separado do core que atende /api/vision/* (proxy interno em
# server.ts). Usa o MESMO JWT_SECRET acima para validar sessão — não defina
# um segredo diferente aqui. Porta é só para comunicação interna (127.0.0.1),
# nunca deve ser exposta publicamente.
VISION_CLOUD_PORT="3101"

# ====== Storage opcional S3-compatível (docs/adr/ADR-011) ======
# Espelha PDF de relatório e backup para um bucket S3-compatível (AWS S3,
# Cloudflare R2, Backblaze B2, MinIO...), além do disco local (que continua
# sendo a fonte de verdade). Vazio/"false" = comportamento atual, só disco
# local — nenhuma env abaixo é obrigatória para o ZappFlow funcionar.
S3_ENABLED=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""              # obrigatório para provedores não-AWS (ex.: R2/MinIO)
S3_FORCE_PATH_STYLE=""      # "true" para provedores que exigem path-style (comum em MinIO)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL_BASE=""       # opcional: domínio público/CDN na frente do bucket

# ====== Fila de jobs em segundo plano (docs/adr/ADR-011) ======
# Move a geração do relatório em PDF do Zapp gestor para fora do ciclo da
# requisição de webhook (JobQueueService). Vazio/ausente = "false" = mantém o
# comportamento síncrono original. Ativar só depois de validar com tráfego
# real de WhatsApp (muda o comportamento observável: o PDF chega como
# mensagem separada, alguns segundos depois da resposta em texto).
PDF_REPORT_ASYNC_ENABLED=""

# ====== ZappFlow Radar de Execução IA (docs/adr/ADR-009) ======
# Kill-switch global de emergência para TODAS as organizações (além do gate por
# tenant, feito pelo módulo opcional 'radar' em Configurações › Módulos).
# Vazio/ausente = ligado (padrão). Defina "false" para desligar o módulo
# inteiro sem precisar de deploy.
AI_EXECUTION_RADAR_ENABLED=""
