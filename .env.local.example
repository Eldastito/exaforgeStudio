# ==============================================================================
# .env.local.example — TEMPLATE para desenvolvimento LOCAL
# ==============================================================================
# Copie este arquivo para `.env.local` e preencha os campos.
# `.env.local` NUNCA é versionado (está no .gitignore).
#
# Este é o ambiente do SEU COMPUTADOR — nada aqui pode ter valor de produção.
# ==============================================================================

# ---- Ambiente ----
NODE_ENV=development

# ---- App / URLs ----
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ---- Storage local ----
DATA_DIR=./data
# (opcional) BACKUPS_DIR=./data/backups

# ---- Segredos LOCAIS (nunca reaproveitar de produção!) ----
# Gere com: openssl rand -hex 32
JWT_SECRET=
# Gere OUTRA chave — dedicada
ENCRYPTION_KEY=

# ---- IA (usa chave separada com budget baixo, ex.: $5-10/mês) ----
OPENAI_API_KEY=
# Modelos (defaults sensatos, deixe em branco pra usar padrão)
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-small
# Guarda-custo em dev: teto baixo pra pegar bug de loop
AI_DAILY_LIMIT=50

# ---- Master admin ----
MASTER_ADMIN_EMAIL=eldastito@gmail.com

# ---- Rate limit em dev: DESLIGADO (mais fácil de testar) ----
ENABLE_RATE_LIMIT=false

# ---- Webhook queue: DESLIGADO em dev (processa inline, mais fácil debugar) ----
WEBHOOK_QUEUE_ENABLED=false

# ==============================================================================
# WhatsApp / Instagram — deixe VAZIO em local, a menos que precise testar
# ==============================================================================
# EVOLUTION_BASE_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE_NAME=ExaFoDEV   # nome DIFERENTE da produção
# META_VERIFY_TOKEN=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=

# ==============================================================================
# Google / Meta Ads / Storage — deixe VAZIO em local
# ==============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# S3_ENABLED=false
