# ==============================================================================
# .env.staging.example — TEMPLATE para o ambiente STAGING no Coolify
# ==============================================================================
# NÃO EXISTE arquivo `.env.staging` no repositório. Este template lista as envs
# que você precisa configurar no PAINEL DO COOLIFY para a aplicação
# `zappflow-staging`.
#
# Regras:
#   1) TODOS os segredos são DIFERENTES da produção.
#   2) DATA_DIR aponta para caminho DIFERENTE (isolamento de banco).
#   3) EVOLUTION_INSTANCE_NAME é de teste (chip separado ou seu WhatsApp pessoal).
#   4) OpenAI: chave dedicada com budget baixo OU a mesma da prod (você escolhe).
#
# Leia docs/AMBIENTES.md antes de configurar.
# ==============================================================================

# ---- Ambiente ----
# Staging usa "production" de propósito — pra reproduzir o comportamento real
# (build compilado, rate limit ligado, log JSON). O que isola é o resto.
NODE_ENV=production

# ---- App / URLs (subdomínio de staging) ----
APP_URL=https://staging.zapflowia.tesseractauto.com.br
ALLOWED_ORIGINS=https://staging.zapflowia.tesseractauto.com.br
CORS_ORIGIN=https://staging.zapflowia.tesseractauto.com.br

# ---- Storage SEPARADO da produção ----
# IMPORTANTE: caminho DIFERENTE. Se apontar pra /data, mistura com prod.
DATA_DIR=/data-staging

# ---- Segredos SEPARADOS da produção ----
# Gere NOVAS chaves. NÃO reaproveitar as de prod.
# Cada uma: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# ---- IA ----
# Recomendado: chave OpenAI separada com budget baixo ($10-20/mês)
OPENAI_API_KEY=
# Guarda-custo em staging: teto baixo pra pegar bug
AI_DAILY_LIMIT=100

# ---- Master admin ----
# Pode ser o mesmo email da prod (você é o mesmo humano)
MASTER_ADMIN_EMAIL=eldastito@gmail.com

# ---- Rate limit LIGADO (simula prod) ----
ENABLE_RATE_LIMIT=true

# ---- Webhook queue LIGADO (padrão em production) ----
# WEBHOOK_QUEUE_ENABLED=true  # já é o default em NODE_ENV=production

# ==============================================================================
# WhatsApp — instância Evolution SEPARADA (chip de teste ou seu pessoal)
# ==============================================================================
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
# IMPORTANTE: nome DIFERENTE da instância de produção pra não conflitar
EVOLUTION_INSTANCE_NAME=ExaFoSTAGING

# ==============================================================================
# Meta / Instagram — só configure se for testar essa integração
# ==============================================================================
# META_VERIFY_TOKEN=
# WEBHOOK_SECRET=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=

# ==============================================================================
# Google — só configure se for testar essa integração
# ==============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==============================================================================
# S3 — opcional (staging não precisa, disco local basta)
# ==============================================================================
# S3_ENABLED=false
