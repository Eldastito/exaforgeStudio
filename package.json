{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:vision-cloud": "tsx apps/vision-cloud/server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:vision-cloud": "esbuild apps/vision-cloud/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/vision-cloud.cjs",
    "build:supervisor": "esbuild scripts/supervisor.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/supervisor.cjs",
    "start": "node dist/server.cjs",
    "start:vision-cloud": "node dist/vision-cloud.cjs",
    "start:supervisor": "node dist/supervisor.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:isolation": "tsx scripts/test-tenant-isolation.ts",
    "test:radar-isolation": "tsx scripts/test-radar-isolation.ts",
    "test:conversion-velocity": "tsx scripts/test-conversion-velocity.ts",
    "test:rbac-audit": "tsx scripts/test-rbac-audit.ts",
    "test:job-queue": "tsx scripts/test-job-queue.ts",
    "test:storage-service": "tsx scripts/test-storage-service.ts",
    "test:radar-public": "tsx scripts/test-radar-public.ts",
    "test:radar-consultant": "tsx scripts/test-radar-consultant.ts",
    "test:radar-evidence": "tsx scripts/test-radar-evidence.ts",
    "test:supervisor": "tsx scripts/test-supervisor.ts",
    "test:vision-foundation": "tsx scripts/test-vision-foundation.ts",
    "test:vision-events": "tsx scripts/test-vision-events.ts",
    "test:vision-incidents": "tsx scripts/test-vision-incidents.ts",
    "test:vision-maestro-bridge": "tsx scripts/test-vision-maestro-bridge.ts",
    "test:vision-webhooks": "tsx scripts/test-vision-webhooks.ts",
    "test:vision-zone-rules": "tsx scripts/test-vision-zone-rules.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "http-proxy-middleware": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "openai": "^6.39.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
